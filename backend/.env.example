# zorder API
NODE_ENV=development
PORT=4000

# SQLite persistence for local demo orders, uploaded inventory, and shop config.
DATABASE_URL=file:./data/zorder.sqlite

# Simple MVP username + 6-digit PIN auth.
# Change these before any public demo.
ZORDER_USER_USERNAME=user
ZORDER_USER_PIN=123456
ZORDER_USER_EMAIL=user@example.com
ZORDER_ADMIN_USERNAME=admin
ZORDER_ADMIN_PIN=654321

# Workflow generation defaults to local deterministic templates.
# Set WORKFLOW_BUILDER_MODE=openai and OPENAI_API_KEY to enable setup-only OpenAI drafting.
WORKFLOW_BUILDER_MODE=local
# OPENAI_API_KEY=
# OPENAI_RESPONSES_URL=https://api.openai.com/v1/responses
# GPT_MODEL=gpt-5.5
