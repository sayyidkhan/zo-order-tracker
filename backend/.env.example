# zorder API
NODE_ENV=development
PORT=4000

# Simple MVP username + 6-digit PIN auth.
# Change these before any public demo.
ZORDER_USER_USERNAME=user
ZORDER_USER_PIN=123456
ZORDER_USER_EMAIL=user@example.com
ZORDER_ADMIN_USERNAME=admin
ZORDER_ADMIN_PIN=654321

# Optional: required only for AI-assisted workflow JSON generation.
# Runtime order processing should work without these.
GPT-API-KEY=
# OPENAI_API_KEY=
OPENAI_RESPONSES_URL=https://api.openai.com/v1/responses
GPT_MODEL=gpt-5.5
# Lower-cost fallback for setup-only workflow generation:
# GPT_MODEL=gpt-5.4-mini

# SQLite persistence for local demo orders and uploaded inventory.
DATABASE_URL=file:./data/zorder.sqlite

# Reserved for future Telegram automation.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_WEBHOOK_SECRET=
