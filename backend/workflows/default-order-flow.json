{
  "id": "default-order-flow",
  "name": "Default Order Flow",
  "version": 1,
  "start": "detect_intent",
  "states": {
    "detect_intent": {
      "type": "decision",
      "rules": [
        {
          "id": "paid_order_request",
          "if": {
            "matchesRegex": "\\b(?:want|buy|reserve|take|can i get|get|need|order)\\b.*\\b(?:paid|paynow|bank transfer|transferred|transfer done|receipt)\\b|\\b(?:paid|paynow|bank transfer|transferred|transfer done|receipt)\\b.*\\b(?:want|buy|reserve|take|can i get|get|need|order)\\b"
          },
          "then": "create_order"
        },
        {
          "id": "paid_quantity_order",
          "if": {
            "containsAny": ["paid", "paynow", "bank transfer", "transferred", "transfer done", "receipt"],
            "matchesRegex": "\\b\\d+\\s+[a-z][a-z\\s-]{1,40}"
          },
          "then": "create_order"
        },
        {
          "id": "payment_update",
          "if": {
            "containsAny": ["paid", "paynow", "bank transfer", "transferred", "transfer done", "sent receipt"]
          },
          "then": "mark_paid"
        },
        {
          "id": "order_request_missing_payment",
          "if": {
            "containsAny": ["want", "buy", "reserve", "take", "can i get", "get", "need"]
          },
          "then": "ask_payment_evidence"
        },
        {
          "id": "explicit_order_request",
          "if": {
            "containsAny": ["order"]
          },
          "then": "ask_payment_evidence"
        },
        {
          "id": "priced_message",
          "if": {
            "amountDetected": true
          },
          "then": "ask_order_confirmation"
        }
      ],
      "else": "needs_review"
    },
    "create_order": {
      "type": "action",
      "action": "create_order"
    },
    "mark_paid": {
      "type": "action",
      "action": "update_payment_status",
      "payment_status": "paid"
    },
    "ask_order_confirmation": {
      "type": "action",
      "action": "ask_follow_up",
      "message": "I found an amount, but I need to confirm whether this is an order.",
      "required_fields": ["order_summary"]
    },
    "ask_payment_evidence": {
      "type": "action",
      "action": "ask_follow_up",
      "message": "Ask for PayNow or bank transfer evidence before capturing this order.",
      "required_fields": ["payment_evidence"]
    },
    "needs_review": {
      "type": "action",
      "action": "needs_review",
      "message": "This input did not match an order or payment rule."
    }
  }
}
